/**
 * Compact configuration.
 * COMPACT_WARN_THRESHOLD: notify user that context is getting large.
 * COMPACT_TIMEOUT_ENABLED: whether to auto-compact on timeout (exit 124).
 */
const COMPACT_WARN_THRESHOLD = 25;
const COMPACT_TIMEOUT_ENABLED = true;

export type CompactEvent =
  | { type: "warn"; turnCount: number }
  | { type: "auto-compact-start" }
  | { type: "auto-compact-done"; success: boolean }
  | { type: "auto-compact-retry"; success: boolean; stdout: string; stderr: string; exitCode: number };

type CompactEventListener = (event: CompactEvent) => void;
const compactListeners: CompactEventListener[] = [];

/** Register a listener for compact-related events (warnings, auto-compact notifications). */
export function onCompactEvent(listener: CompactEventListener): void {
  compactListeners.push(listener);
}

function emitCompactEvent(event: CompactEvent): void {
  for (const listener of compactListeners) {
    try { listener(event); } catch {}
  }
}

export interface RunResult {
  stdout: string;
  stderr: string;
  exitCode: number;
  /** Human-readable: which slot and model answered (Telegram/Discord prefix). */
  modelTag?: string;
}

const ZAI_ANTHROPIC_BASE = "https://api.z.ai/api/anthropic";
const OPENROUTER_ANTHROPIC_BASE = "https://openrouter.ai/api";

type ModelProvider = "anthropic" | "glm" | "openrouter";

function modelProvider(model: string): ModelProvider {
  const m = model.trim().toLowerCase();
  if (m === "glm" || m.startsWith("glm/")) return "glm";
  if (m === "openrouter" || m.startsWith("openrouter/")) return "openrouter";
  return "anthropic";
}

/**
 * Value for `claude --model`. GLM often omits it; OpenRouter uses the slug after `openrouter/`.
 */
function claudeCliModelArg(model: string): string | undefined {
  const t = model.trim();
  if (!t) return undefined;
  const prov = modelProvider(t);
  if (prov === "glm") return undefined;
  if (prov === "openrouter") {
    const low = t.toLowerCase();
    if (low === "openrouter") return undefined;
    if (low.startsWith("openrouter/")) return t.slice("openrouter/".length);
    return undefined;
  }
  if (t.toLowerCase().startsWith("glm/")) return t.slice(t.indexOf("/") + 1);
  return t;
}

function buildModelTag(
  usedFallback: boolean,
  effective: ModelConfig,
  agentic: boolean,
  taskType: string,
): string {
  const slot = usedFallback ? "fallback" : "primary";
  const name = effective.model.trim() || "(default API model)";
  return agentic ? `${slot} · ${name} · ${taskType}` : `${slot} · ${name}`;
}

// Triggers a retry with fallback model/api. Claude CLI often prints quota errors on stdout, not stderr.
// Match both the raw blob and the JSON `result` string (see extractRateLimitMessage).
const RATE_LIMIT_PATTERN =
  /you.ve hit your limit|\bhit your limit\b|\breached your limit\b|out of extra usage|API Error:\s*429|\brate_limit|insufficient balance|no resource package|please recharge|credit exhausted|overloaded_error|usage limit|too many requests|resets\s+\d|europe\/berlin/i;

/** Claude `-p --output-format json` usually emits `type: "result"`; some builds omit `type` but still include `result`. */
export function tryParseClaudeCliResultJson(text: string): {
  result?: string;
  is_error?: boolean;
  session_id?: string;
} | null {
  let t = text.trim();
  const idx = t.indexOf("{");
  if (idx > 0) t = t.slice(idx);
  if (!t.startsWith("{")) return null;
  try {
    const o = JSON.parse(t) as Record<string, unknown>;
    if (typeof o.result !== "string") return null;
    if (o.type !== undefined && o.type !== "result") return null;
    return {
      result: o.result,
      is_error: o.is_error === true,
      session_id: typeof o.session_id === "string" ? o.session_id : undefined,
    };
  } catch {
    return null;
  }
}

/** Prefer CLI `result` text when stdout/stderr is JSON; otherwise first non-empty stream. */
export function humanReadableFromClaudeCliOutput(stdout: string, stderr: string): string {
  const s = stdout.trim();
  const e = stderr.trim();
  const fromOut = tryParseClaudeCliResultJson(s);
  if (fromOut?.result?.trim()) return fromOut.result.trim();
  const fromErr = tryParseClaudeCliResultJson(e);
  if (fromErr?.result?.trim()) return fromErr.result.trim();
  return e || s || "Unknown error";
}

function textLooksLikeRateLimit(text: string): boolean {
  return RATE_LIMIT_PATTERN.test(text);
}

function extractRateLimitMessage(stdout: string, stderr: string): string | null {
  for (const text of [stdout, stderr]) {
    const trimmed = text.trim();
    if (!trimmed) continue;
    if (textLooksLikeRateLimit(trimmed)) return trimmed;
    const parsed = tryParseClaudeCliResultJson(trimmed);
    if (parsed?.result && textLooksLikeRateLimit(parsed.result)) return trimmed;
  }
  // If JSON shape changed or text is split oddly, humanReadable still matches what the user sees.
  const human = humanReadableFromClaudeCliOutput(stdout, stderr);
  if (human && human !== "Unknown error" && textLooksLikeRateLimit(human)) {
    return stdout.trim() || stderr.trim() || human;
  }
  return null;
}

// Serial queue — prevents concurrent --resume on the same session
// Global queue for non-thread messages (backward compatible)
let globalQueue: Promise<unknown> = Promise.resolve();
// Per-thread queues — each thread runs independently in parallel
const threadQueues = new Map<string, Promise<unknown>>();

function enqueue<T>(fn: () => Promise<T>, threadId?: string): Promise<T> {
  if (threadId) {
    const current = threadQueues.get(threadId) ?? Promise.resolve();
    const task = current.then(fn, fn);
    threadQueues.set(threadId, task.catch(() => {}));
    return task;
  }
  const task = globalQueue.then(fn, fn);
  globalQueue = task.catch(() => {});
  return task;
}

/** Transcript blocks from extended thinking are signed per model/API; --resume breaks after a switch. */
const THINKING_SIGNATURE_PATTERN =
  /Invalid [`']signature[`'] in [`']thinking[`'] block|thinking[`'] block.*signature|invalid_request_error.*thinking/i;

function isThinkingSignatureError(stdout: string, stderr: string): boolean {
  return (
    THINKING_SIGNATURE_PATTERN.test(stdout) || THINKING_SIGNATURE_PATTERN.test(stderr)
  );
}

/** OpenRouter/SiliconFlow/DeepInfra reject transcripts with split streaming assistant rows or bad tool ordering. */
function isOpenAiCompatTranscriptError(stdout: string, stderr: string): boolean {
  const t = `${stdout}\n${stderr}`;
  return (
    /Tool message at position|must follow an assistant message with tool_calls/i.test(t) ||
    /"messages" in request are illegal|messages.*illegal|\b20015\b/i.test(t)
  );
}

function buildClaudeInvokeArgs(
  prompt: string,
  securityArgs: string[],
  appendSystemPrompt: string,
  resumeSessionId: string | null,
): string[] {
  const outputFormat = resumeSessionId ? "text" : "json";
  const args = ["claude", "-p", prompt, "--output-format", outputFormat, ...securityArgs];
  if (resumeSessionId) args.push("--resume", resumeSessionId);
  if (appendSystemPrompt.trim()) {
    args.push("--append-system-prompt", appendSystemPrompt);
  }
  return args;
}

function resumeIdFromClaudeArgs(args: string[]): string | null {
  const idx = args.indexOf("--resume");
  if (idx === -1 || idx + 1 >= args.length) return null;
  const id = args[idx + 1];
  return typeof id === "string" && id.trim().length > 0 ? id.trim() : null;
}

function sameModelConfig(a: ModelConfig, b: ModelConfig): boolean {
  return a.model.trim().toLowerCase() === b.model.trim().toLowerCase() && a.api.trim() === b.api.trim();
}

function hasModelConfig(value: ModelConfig): boolean {
  return value.model.trim().length > 0 || value.api.trim().length > 0;
}

function isNotFoundError(error: unknown): boolean {
  if (!error || typeof error !== "object") return false;
  const code = (error as { code?: unknown }).code;
  if (code === "ENOENT") return true;
  const message = String((error as { message?: unknown }).message ?? "");
  return /enoent|no such file or directory/i.test(message);
}

function buildChildEnv(baseEnv: Record<string, string>, model: string, api: string): Record<string, string> {
  const childEnv: Record<string, string> = { ...baseEnv };

  if (api.trim()) childEnv.ANTHROPIC_AUTH_TOKEN = api.trim();

  const prov = modelProvider(model);
  if (prov === "glm") {
    childEnv.ANTHROPIC_BASE_URL = ZAI_ANTHROPIC_BASE;
    childEnv.API_TIMEOUT_MS = "3000000";
  } else if (prov === "openrouter") {
    childEnv.ANTHROPIC_BASE_URL = OPENROUTER_ANTHROPIC_BASE;
  }

  // Print mode (-p) + third-party gateways often return 400 "tool use concurrency" when many
  // read-only tools/subagents run in parallel. Default Claude Code is 10; sequential is safer here.
  if (!childEnv.CLAUDE_CODE_MAX_TOOL_USE_CONCURRENCY?.trim()) {
    childEnv.CLAUDE_CODE_MAX_TOOL_USE_CONCURRENCY = "1";
  }
  // Proxies sometimes duplicate tool execution on streaming fallback → 400 concurrency / duplicate ids.
  if (!childEnv.CLAUDE_CODE_DISABLE_NONSTREAMING_FALLBACK?.trim()) {
    childEnv.CLAUDE_CODE_DISABLE_NONSTREAMING_FALLBACK = "1";
  }

  return childEnv;
}

/** Default when `runClaudeOnce` is called without an explicit budget (matches config default). */
const CLAUDE_TIMEOUT_MS = 15 * 60 * 1000;

async function runClaudeOnce(
  baseArgs: string[],
  model: string,
  api: string,
  baseEnv: Record<string, string>,
  timeoutMs: number = CLAUDE_TIMEOUT_MS
): Promise<{ rawStdout: string; stderr: string; exitCode: number }> {
  const args = [...baseArgs];
  const mArg = claudeCliModelArg(model);
  if (mArg) args.push("--model", mArg);

  const proc = Bun.spawn(args, {
    stdout: "pipe",
    stderr: "pipe",
    env: buildChildEnv(baseEnv, model, api),
  });

  const timeoutPromise = new Promise<never>((_, reject) => {
    setTimeout(() => reject(new Error(`Claude session timed out after ${timeoutMs / 1000}s`)), timeoutMs);
  });

  try {
    const [rawStdout, stderr] = await Promise.race([
      Promise.all([
        new Response(proc.stdout).text(),
        new Response(proc.stderr).text(),
      ]),
      timeoutPromise,
    ]) as [string, string];
    await proc.exited;

    return {
      rawStdout,
      stderr,
      exitCode: proc.exitCode ?? 1,
    };
  } catch (err) {
    // Kill the hung process
    try { proc.kill("SIGTERM"); } catch {}
    setTimeout(() => { try { proc.kill("SIGKILL"); } catch {} }, 5000);

    const message = err instanceof Error ? err.message : String(err);
    console.error(`[${new Date().toLocaleTimeString()}] ${message}`);

    return {
      rawStdout: "",
      stderr: message,
      exitCode: 124,
    };
  }
}

